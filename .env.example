# Base URL of the Workers API. Leave as-is for prod. Point to
# http://localhost:8787 when running the Workers locally.
PUBLIC_API_BASE_URL=https://api.nebularnews.com

# Base URL of this web app. Used to build Apple Sign In callback URLs.
PUBLIC_WEB_BASE_URL=https://admin.nebularnews.com

# Dev-only bypass: if set, the /sign-in page accepts a paste-in session
# token so you can poke around before Apple Sign In for Web is configured.
# Leave BLANK or remove for any environment that isn't your local machine.
DEV_BYPASS_ENABLED=true
